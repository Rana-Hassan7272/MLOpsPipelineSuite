# Git
.git
.github
.gitignore

# Python cache and compiled
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/*.egg-info
**/*.egg

# Virtual environments
venv
.venv
env
ENV

# IDE
.cursor
.vscode
.idea
*.swp
*.swo
*~

# Logs and databases
*.log
*.sqlite
**/*.db-journal
*.db

# OS files
**/.DS_Store
Thumbs.db

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation (not needed in image)
README.md
roadmap.md
images/
results/*.md

# CI (not needed in production image)
.github/

# Data that should be mounted, not copied
data/
datasets/*
!datasets/.gitkeep
experiments/mlruns/*
!experiments/mlruns/.gitkeep

# Test files (dev only)
tests/
.pytest_cache/
.coverage
htmlcov/

# Kubernetes manifests (not needed in image)
k8s/
